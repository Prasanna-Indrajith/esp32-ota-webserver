{
  "name": "esp32-ota-server",
  "version": "1.0.0",
  "description": "ESP32 OTA firmware update server — Node.js/Express + Vanilla JS",
  "type": "module",
  "main": "server/server.js",
  "scripts": {
    "start":  "node server/server.js",
    "dev":    "node --watch server/server.js",
    "setup":  "node scripts/setup.js",
    "audit":  "npm audit --audit-level=high"
  },
  "keywords": ["esp32","ota","firmware","express"],
  "license": "MIT",
  "dependencies": {
    "bcrypt":               "^5.1.1",
    "dotenv":               "^16.4.5",
    "express":              "^4.19.2",
    "express-rate-limit":   "^7.3.1",
    "express-session":      "^1.18.0",
    "helmet":               "^7.1.0",
    "multer":               "^1.4.5-lts.1"
  }
}
