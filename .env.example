# Copy this to .env and fill in your values
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-long-random-string

# Generate with: node -e "const b=require('bcrypt');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$replace-with-bcrypt-hash-of-your-password

# Firmware settings
MAX_FIRMWARE_MB=10
KEEP_OLD_VERSIONS=3
ROLLBACK_EXPIRE_MIN=15
